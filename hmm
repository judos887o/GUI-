                if targetId then
                    -- Präsenzprüfung: Ist der Spieler überhaupt in unserem Roblox-Server?
                    local targetPlayer = Players:GetPlayerByUserId(targetId)
                    
                    if targetPlayer then
                        local row = Instance.new("Frame", UsersScroll)
                        row.Size = UDim2.new(0.95, 0, 0, s(28))
                        row.BackgroundColor3 = Color3.fromRGB(20, 14, 14)
                        Instance.new("UICorner", row).CornerRadius = UDim.new(0, s(4))
                        Instance.new("UIStroke", row).Color = Color3.fromRGB(50, 20, 20)

                        local pName = Instance.new("TextLabel", row)
                        pName.Size = UDim2.new(0.6, 0, 1, 0)
                        pName.Position = UDim2.new(0, s(6), 0, 0)
                        pName.BackgroundTransparency = 1
                        
                        -- Hebe dich selbst in der Liste hervor
                        local displayName = data.DisplayName or data.Username
                        if targetId == lp.UserId then
                            displayName = displayName .. " (You)"
                        end
                        
                        pName.Text = displayName
                        pName.TextColor3 = targetId == lp.UserId and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(255, 255, 255)
                        pName.Font = Enum.Font.GothamSemibold
                        pName.TextSize = s(10)
                        pName.TextXAlignment = Enum.TextXAlignment.Left

                        local selBtn = Instance.new("TextButton", row)
                        selBtn.Size = UDim2.new(0.35, 0, 0.7, 0)
                        selBtn.Position = UDim2.new(0.62, 0, 0.15, 0)
                        selBtn.BackgroundColor3 = Color3.fromRGB(150, 30, 30)
                        selBtn.Text = "SELECT"
                        selBtn.Font = Enum.Font.GothamBold
                        selBtn.TextSize = s(8)
                        selBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                        Instance.new("UICorner", selBtn).CornerRadius = UDim.new(0, s(3))

                        selBtn.MouseButton1Click:Connect(function()
                            playClick()
                            SelectedPlayerId = targetId
                            SelectedPlayerName = data.Username
                            TargetName.Text = displayName .. " (@" .. data.Username .. ")"
                            TargetPFP.Image = "rbxthumb://type=AvatarHeadShot&id=" .. targetId .. "&w=150&h=150"
                            logAction("Target selected!")
                        end)
                    end
                end
            end
        end

        Shared.UpdateUserListFunction = UpdateUserList

        local function toggleAdminPanel(st)
            MainAdmin.Visible = st
            if st then UpdateUserList() end
        end

        Shared.AdminPanelToggleLogic = toggleAdminPanel
        
        -- Aktualisiert die Benutzeroberfläche alle 2 Sekunden aus dem Speicher
        task.spawn(function()
            while true do
                if MainAdmin.Visible then
                    pcall(UpdateUserList)
                end
                task.wait(2)
            end
        end)
    end

