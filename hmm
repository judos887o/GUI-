    local activeMarkers = {}
    
    local function updateShadowPepperMarkers()
        -- Markiere alle registrierten Spieler
        for _, player in ipairs(Players:GetPlayers()) do
            local inDb = CachedUsers[tostring(player.UserId)] or CachedUsers[player.UserId]
            
            if inDb or player == lp then
                player:SetAttribute("ShadowPepperUser", true)
            else
                player:SetAttribute("ShadowPepperUser", nil)
            end
        end

        -- 3D Marker rendern
        for _, player in ipairs(Players:GetPlayers()) do
            if player:GetAttribute("ShadowPepperUser") == true then
                local char = player.Character
                if char then
                    local head = char:FindFirstChild("Head")
                    if head then
                        local marker = activeMarkers[player]
                        if not marker or marker.Parent ~= char then
                            if marker then pcall(function() marker:Destroy() end) end
                            
                            local bb = Instance.new("BillboardGui")
                            bb.Name = "ShadowPepperUserMarker"
                            bb.Adornee = head
                            bb.Size = UDim2.new(0, 100, 0, 50)
                            bb.StudsOffset = Vector3.new(0, 3.5, 0)
                            bb.AlwaysOnTop = true
                            bb.Parent = char
                            
                            local imgFrame = Instance.new("Frame", bb)
                            imgFrame.Size = UDim2.new(0, 30, 0, 30)
                            imgFrame.Position = UDim2.new(0.5, -15, 0, 0)
                            imgFrame.BackgroundColor3 = Color3.fromRGB(14, 10, 10)
                            imgFrame.BorderSizePixel = 0
                            Instance.new("UICorner", imgFrame).CornerRadius = UDim.new(1, 0)
                            local stroke = Instance.new("UIStroke", imgFrame)
                            stroke.Color = Color3.fromRGB(255, 40, 40)
                            stroke.Thickness = 1.5

                            local img = Instance.new("ImageLabel", imgFrame)
                            img.Size = UDim2.new(1, -4, 1, -4)
                            img.Position = UDim2.new(0, 2, 0, 2)
                            img.BackgroundTransparency = 1
                            img.Image = LOGO_ASSET
                            Instance.new("UICorner", img).CornerRadius = UDim.new(1, 0)
                            
                            local textLabel = Instance.new("TextLabel", bb)
                            textLabel.Size = UDim2.new(1, 0, 0, 15)
                            textLabel.Position = UDim2.new(0, 0, 0, 32)
                            textLabel.BackgroundTransparency = 1
                            textLabel.Text = player == lp and "You" or "Shadowpepper user"
                            textLabel.TextColor3 = player == lp and Color3.fromRGB(255, 120, 120) or Color3.fromRGB(255, 255, 255)
                            textLabel.Font = Enum.Font.GothamBold
                            textLabel.TextSize = 9
                            textLabel.TextStrokeTransparency = 0.2
                            textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                            
                            activeMarkers[player] = bb
                        end
                        local bb = activeMarkers[player]
                        if bb then
                            local bobOffset = math.sin(tick() * 3) * 0.15
                            bb.StudsOffset = Vector3.new(0, 3.5 + bobOffset, 0)
                        end
                    end
                else
                    activeMarkers[player] = nil
                end
            else
                if activeMarkers[player] then
                    pcall(function() activeMarkers[player]:Destroy() end)
                    activeMarkers[player] = nil
                end
            end
        end
    end
    table.insert(RenderConnections, RunService.RenderStepped:Connect(updateShadowPepperMarkers))

