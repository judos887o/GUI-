    local function getPad(padName)
        local map = Workspace:FindFirstChild("MAP")
        if not map then return nil end
        local targets = {}
        if map:FindFirstChild("Shops") then table.insert(targets, map.Shops) end
        if map:FindFirstChild("Pads") then table.insert(targets, map.Pads) end
        local cleanSearchName = padName:gsub("[%[%]]", ""):lower()
        for _, folder in ipairs(targets) do
            for _, v in ipairs(folder:GetChildren()) do
                local cd = v:FindFirstChildWhichIsA("ClickDetector") or v:FindFirstChild("ClickDetector")
                if cd then
                    if v.Name == padName then return v end
                    local cleanVName = v.Name:gsub("[%[%]]", ""):lower()
                    if cleanVName == cleanSearchName then return v end
                    if string.find(v.Name:lower(), cleanSearchName, 1, true) or string.find(cleanVName, cleanSearchName, 1, true) then
                        return v
                    end
                end
            end
        end
        return nil
    end

