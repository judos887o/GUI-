local function dbWrite(path, data)
    pcall(function()
        request({
            Url = FIREBASE_URL .. path .. ".json",
            Method = "PUT",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode(data)
        })
    end)
end

local function dbRead(path)
    local success, response = pcall(function()
        return request({
            Url = FIREBASE_URL .. path .. ".json",
            Method = "GET"
        })
    end)
    if success and response then
        local statusCode = response.StatusCode or response.Status
        if (statusCode == 200 or statusCode == 201) and response.Body and response.Body ~= "null" then
            local ok, decoded = pcall(function() return HttpService:JSONDecode(response.Body) end)
            if ok then return decoded end
        end
    end
    return nil
end

local function dbDelete(path)
    pcall(function()
        request({
            Url = FIREBASE_URL .. path .. ".json",
            Method = "DELETE"
        })
    end)
end

