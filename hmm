        local function RefreshUsers()
            for _, c in ipairs(uScroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
            if not CachedServers then return end
            for sId, sData in pairs(CachedServers) do
                local users = sData.users or {}
                for uIdStr, data in pairs(users) do
                    local tId = tonumber(uIdStr)
                    if tId then
                        local row = Instance.new("Frame", uScroll)
                        row.Size = UDim2.new(0.92, 0, 0, s(28))
                        row.BackgroundColor3 = Color3.fromRGB(30, 25, 30)
                        Instance.new("UICorner", row).CornerRadius = UDim.new(0, s(5))

                        local lbl = Instance.new("TextLabel", row)
                        lbl.Size = UDim2.new(0.65, 0, 1, 0)
                        lbl.Position = UDim2.new(0, s(6), 0, 0)
                        lbl.BackgroundTransparency = 1
                        lbl.Text = data.DisplayName or data.Username
                        lbl.Font = Enum.Font.GothamSemibold
                        lbl.TextSize = s(9)
                        lbl.TextColor3 = tId == lp.UserId and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(255, 255, 255)
                        lbl.TextXAlignment = Enum.TextXAlignment.Left

                        local sel = Instance.new("TextButton", row)
                        sel.Size = UDim2.new(0.28, 0, 0.7, 0)
                        sel.Position = UDim2.new(0.7, 0, 0.15, 0)
                        sel.BackgroundColor3 = Color3.fromRGB(200, 45, 45)
                        sel.Text = "SEL"
                        sel.Font = Enum.Font.GothamBold
                        sel.TextColor3 = Color3.fromRGB(255, 255, 255)
                        sel.TextSize = s(8)
                        Instance.new("UICorner", sel).CornerRadius = UDim.new(0, s(4))

                        sel.MouseButton1Click:Connect(function()
                            playClick()
                            selId = tId
                            selName = data.Username
                            selServerId = sId
                            cName.Text = (data.DisplayName or data.Username) .. " (@" .. data.Username .. ")"
                            cHeadshot.Image = "rbxthumb://type=AvatarHeadShot&id=" .. tId .. "&w=150&h=150"
                            if sId ~= ServerID then
                                tpBtn.Visible = true
                                logAct("User is in another server!")
                            else
                                tpBtn.Visible = false
                                logAct("User is in your server!")
                            end
