local function CleanupSilentAim()
    DisableSilentAimFlags()
    local df = {"SilentAim_Q_Destroy", "SilentAim_FOV_Destroy", "DisableSilentAim", "StopSilentAim", "SilentAimDestroy"}
    for _, fn in ipairs(df) do if getgenv()[fn] then pcall(getgenv()[fn]) getgenv()[fn] = nil end end
    if Shared.Connections then
        for k, l in pairs(Shared.Connections) do
            local kl = tostring(k):lower()
            if kl:find("silent") or kl:find("aim") or kl:find("fov") then
                if type(l) == "table" then for _, c in ipairs(l) do pcall(function() c:Disconnect() end) end end
                Shared.Connections[k] = nil
            end
        end
    end
    local cn = {"SilentAimConnection", "SilentAimRender", "SilentAimLoop", "FOVConnection"}
    for _, n in ipairs(cn) do if getgenv()[n] then pcall(function() getgenv()[n]:Disconnect() end) getgenv()[n] = nil end end
    local un = {"Schmeckt_SilentAim_UI", "Schmeckt_SilentAim_FOV_UI", "SchmecktSilentAim"}
    for _, n in ipairs(un) do
        local g = CoreGui:FindFirstChild(n) if g then g:Destroy() end
    end
    local dn = {"SilentAimFOVCircle", "FOVCircle", "AimCircle"}
    for _, n in ipairs(dn) do if getgenv()[n] then pcall(function() getgenv()[n]:Remove() end) getgenv()[n] = nil end end
end

