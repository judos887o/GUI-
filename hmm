    local padBillboards = {}
    local playerBillboards = {}

    local weaponNames = { ["[Silencer]"] = true, ["[Tactical Shotgun]"] = true, ["[USP]"] = true }
    local foodNames = { ["[Bloxy Cola]"] = true, ["[Pizza]"] = true }

    local function ensurePlayerBillboard(plr)
        local char = plr.Character
        if not char then return end
        local head = char:FindFirstChild("Head") or char:FindFirstChildWhichIsA("BasePart")
        if not head then return end

        local bb = playerBillboards[plr]
        if not bb or bb.Parent ~= char then
            if bb then pcall(function() bb:Destroy() end) end
            bb = Instance.new("BillboardGui")
            bb.Name = "SchmecktPlayerESP"
            bb.Adornee = head
            bb.Size = UDim2.new(0, 250, 0, 75)
            bb.StudsOffset = Vector3.new(0, 3.5, 0)
            bb.AlwaysOnTop = true
            bb.Parent = char

            local txt = Instance.new("TextLabel")
            txt.Name = "EspText"
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.Font = Enum.Font.GothamBold
            txt.TextSize = 11
            txt.TextStrokeTransparency = 0.2
            txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            txt.RichText = true
            txt.Parent = bb
            playerBillboards[plr] = bb
        end

        local hum = char:FindFirstChildOfClass("Humanoid")
        local hp = hum and math.floor(hum.Health) or 0
        local maxHp = hum and math.floor(hum.MaxHealth) or 100
        local armor = char:GetAttribute("Armor") or 0
        local equippedTool = char:FindFirstChildOfClass("Tool")
        local toolName = equippedTool and equippedTool.Name:gsub("[%[%]]", "") or "None"

        bb.EspText.Text = string.format("<font color='rgb(255, 255, 255)'><b>%s</b></font>\n<font color='rgb(255, 80, 80)'>❤ %d/%d HP</font>  |  <font color='rgb(100, 180, 255)'>🛡 %s AP</font>\n<font color='rgb(255, 210, 80)'>🔫 %s</font>", plr.DisplayName, hp, maxHp, tostring(armor), toolName)
    end

    local function removePlayerBillboard(plr)
        if playerBillboards[plr] then pcall(function() playerBillboards[plr]:Destroy() end) playerBillboards[plr] = nil end
    end

    local function ensurePadBillboard(pad, labelText, color)
        if padBillboards[pad] then padBillboards[pad].Enabled = true return end
        local headPart = pad:FindFirstChild("Head") or pad:FindFirstChildWhichIsA("BasePart")
        if not headPart then return end
        local bb = Instance.new("BillboardGui", pad)
        bb.Name = "SchmecktPadESP"
        bb.Adornee = headPart
        bb.Size = UDim2.new(0, 200, 0, 30)
        bb.StudsOffset = Vector3.new(0, 4, 0)
        bb.AlwaysOnTop = true

        local txt = Instance.new("TextLabel", bb)
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Text = labelText
        txt.TextColor3 = color
        txt.Font = Enum.Font.GothamBlack
        txt.TextSize = 14
        txt.TextStrokeTransparency = 0.3
        txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        padBillboards[pad] = bb
    end

    local function removePadBillboard(pad)
        if padBillboards[pad] then padBillboards[pad]:Destroy() padBillboards[pad] = nil end
    end

    local function renderESP()
        for _, l in ipairs(lines) do l.Visible = false end
        if Shared.EspPlayers then
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= lp and plr.Character then
                    local char = plr.Character
                    local root = char:FindFirstChild("HumanoidRootPart")
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if root and hum and hum.Health > 0 then
                        if not char:FindFirstChild("SchmecktHighlight") then
                            local hl = Instance.new("Highlight", char)
                            hl.Name = "SchmecktHighlight"
                            hl.FillColor = Color3.fromRGB(160, 0, 0)
                            hl.OutlineColor = Color3.fromRGB(255, 80, 80)
                            hl.FillTransparency = 0.5
                            hl.OutlineTransparency = 0.2
                        end
                        ensurePlayerBillboard(plr)
                    else
                        removePlayerBillboard(plr)
                    end
                else
                    removePlayerBillboard(plr)
                end
            end
        else
            for _, plr in pairs(Players:GetPlayers()) do
                if plr.Character and plr.Character:FindFirstChild("SchmecktHighlight") then plr.Character.SchmecktHighlight:Destroy() end
                removePlayerBillboard(plr)
            end
        end

        if Shared.TracersEnabled then
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= lp and plr.Character then
                    local root = plr.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        local vec, onScreen = Camera:WorldToViewportPoint(root.Position)
                        if onScreen then
                            local line = getLine()
                            local startPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                            local endPos = Vector2.new(vec.X, vec.Y)
                            local distance = (endPos - startPos).Magnitude
                            local center = (startPos + endPos) / 2
                            local angle = math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X)
                            line.Size = UDim2.new(0, distance, 0, 1.5)
                            line.Position = UDim2.new(0, center.X, 0, center.Y)
                            line.Rotation = math.deg(angle)
                            line.Visible = true
                        end
                    end
                end
            end
        end

        local map = Workspace:FindFirstChild("MAP")
        local padsFolder = map and map:FindFirstChild("Pads")
        if padsFolder then
            for _, pad in ipairs(padsFolder:GetChildren()) do
                if weaponNames[pad.Name] then
                    if Shared.EspWeapons then ensurePadBillboard(pad, pad.Name, Color3.fromRGB(255, 50, 50)) else removePadBillboard(pad) end
                elseif foodNames[pad.Name] then
                    if Shared.EspFood then ensurePadBillboard(pad, pad.Name, Color3.fromRGB(50, 255, 100)) else removePadBillboard(pad) end
                end
            end
        end
    end
    table.insert(RenderConnections, RunService.RenderStepped:Connect(renderESP))

    local defaultCollisions = setmetatable({}, {__mode = "k"})
    local function applyNoclipState(char, enabled)
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then
                if enabled then
                    if defaultCollisions[p] == nil then defaultCollisions[p] = p.CanCollide end
                    p.CanCollide = false
                else
                    local def = defaultCollisions[p]
                    if def ~= nil then p.CanCollide = def end
                end
            end
        end
    end

    table.insert(RenderConnections, RunService.Stepped:Connect(function()
        local char = lp.Character
        if char then applyNoclipState(char, Shared.IsNoclip or Shared.IsFly) end
    end))

    table.insert(RenderConnections, RunService.Heartbeat:Connect(function(dt)
        local char = lp.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local camCF = Camera.CFrame

        if Shared.IsFly then
            local moveDir = Vector3.new(0, 0, 0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camCF.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camCF.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camCF.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camCF.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end
            if moveDir.Magnitude > 0 then root.CFrame = root.CFrame + (moveDir.Unit * Shared.SpeedVal * dt) end
            root.AssemblyLinearVelocity = Vector3.zero
        elseif Shared.IsTPWalk then
            local moveDir = Vector3.new(0, 0, 0)
            local forward = camCF.LookVector * Vector3.new(1, 0, 1)
            local right = camCF.RightVector * Vector3.new(1, 0, 1)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + forward end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - forward end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - right end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + right end
            if moveDir.Magnitude > 0 then
                root.CFrame = root.CFrame + (moveDir.Unit * Shared.SpeedVal * dt)
                root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
            end
        end
    end))

    local MAINEVENT = ReplicatedStorage:FindFirstChild("MAINEVENT") or ReplicatedStorage:WaitForChild("MAINEVENT", 5)
    local function isKnocked(plr)
        local char = plr.Character
        local be = char and char:FindFirstChild("BodyEffects")
        local ko = be and (be:FindFirstChild("K.O") or be:FindFirstChild("KO") or be:FindFirstChild("Knocked"))
        if ko and ko.Value == true then return true end
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        return hum and hum.Health <= 15
    end

    table.insert(RenderConnections, RunService.Heartbeat:Connect(function()
        if not Shared.InstantStomp then return end
        local myHrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not myHrp then return end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= lp and isKnocked(p) and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp and (myHrp.Position - hrp.Position).Magnitude <= 15 then
                    if MAINEVENT then MAINEVENT:FireServer("STOMP") end
                end
            end
        end
    end))

    local OriginalVelocity, OriginalAngularVelocity
    local directionsMap = { Behind = Vector3.new(0, 0, -1), Forward = Vector3.new(0, 0, 1), Left = Vector3.new(-1, 0, 0), Right = Vector3.new(1, 0, 0), Down = Vector3.new(0, -1, 0), Up = Vector3.new(0, 1, 0), Zero = Vector3.new(0, 0, 0) }

    table.insert(RenderConnections, RunService.Heartbeat:Connect(function()
        if not getgenv().Desync then return end
        local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        OriginalVelocity, OriginalAngularVelocity = root.AssemblyLinearVelocity, root.AssemblyAngularVelocity
        local dir = directionsMap[getgenv().DirectionToShoot] or Vector3.new(0, 0, -1)
        root.AssemblyLinearVelocity = (dir * 800000) + Vector3.new(math.random(-100, 100), 0, math.random(-100, 100))
        root.AssemblyAngularVelocity = Vector3.new(math.random(-8000, 8000), math.random(-8000, 8000), math.random(-8000, 8000))
        RunService.RenderStepped:Wait()
        root.AssemblyLinearVelocity, root.AssemblyAngularVelocity = OriginalVelocity, OriginalAngularVelocity
    end))

    local activeMarkers = {}
    local function drawCloudMarkers()
        if not CachedServers then return end
        local currentServerData = CachedServers[ServerID]
        local localUsers = currentServerData and currentServerData.users or {}
        for _, player in ipairs(Players:GetPlayers()) do
            local exists = localUsers[tostring(player.UserId)] or player == lp
            if exists then
                local head = player.Character and player.Character:FindFirstChild("Head")
                if head then
                    local marker = activeMarkers[player]
                    if not marker or marker.Parent ~= player.Character then
                        if marker then marker:Destroy() end
                        local bb = Instance.new("BillboardGui", player.Character)
                        bb.Size = UDim2.new(0, 100, 0, 50)
                        bb.StudsOffset = Vector3.new(0, 3.5, 0)
                        bb.AlwaysOnTop = true
                        local box = Instance.new("Frame", bb)
