    local platBtns = {}
    local platOpts = {"PC", "Mobile"}
    local updateMethods
    local CamlockToggleRef 

    for i, opt in ipairs(platOpts) do
        local b = Instance.new("TextButton", PlatformRow)
        b.Size = UDim2.new(0.5, 0, 1, 0)
        b.Position = UDim2.new(0.5 * (i - 1), 0, 0, 0)
        b.BackgroundColor3 = Shared.Platform == opt and Color3.fromRGB(150, 30, 30) or Color3.fromRGB(20, 14, 14)
        b.Text = opt
        b.Font = Enum.Font.GothamBold
        b.TextSize = s(11)
        b.TextColor3 = Shared.Platform == opt and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 120, 120)
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, s(6))
        table.insert(platBtns, b)

        b.MouseButton1Click:Connect(function()
            playClick()
            Shared.Platform = opt
            for idx, ob in ipairs(platBtns) do
                ob.BackgroundColor3 = platOpts[idx] == opt and Color3.fromRGB(150, 30, 30) or Color3.fromRGB(20, 14, 14)
                ob.TextColor3 = platOpts[idx] == opt and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 120, 120)
            end
            SaveConfig()
            if updateMethods then updateMethods() end
            if CamlockToggleRef then 
                CamlockToggleRef.Label.Text = Shared.Platform == "PC" and "Camlock (Q)" or "Camlock"
            end
            if Shared.SilentAim then Load_SilentMethod() end
            if Shared.Camlock then Load_CamlockMethod() end
        end)
    end

    CreateSection("Silent Aim")

    orderCount = orderCount + 1
    local MethodRow = Instance.new("Frame", Scroll)
    MethodRow.Size = UDim2.new(0.9, 0, 0, s(32))
    MethodRow.BackgroundColor3 = Color3.fromRGB(20, 14, 14)
    MethodRow.LayoutOrder = orderCount
    Instance.new("UICorner", MethodRow).CornerRadius = UDim.new(0, s(6))
    Instance.new("UIStroke", MethodRow).Color = Color3.fromRGB(50, 20, 20)

    updateMethods = function()
        for _, c in ipairs(MethodRow:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        
        local opts = {}
        if Shared.Platform == "PC" then
            opts = { {id="QMethod", txt="Q-Method"}, {id="FOV", txt="FOV Method"} }
            if Shared.SilentAimMethod == "MobileMethod" then Shared.SilentAimMethod = "QMethod" end
        else
            opts = { {id="MobileMethod", txt="Mobile Method"} }
            Shared.SilentAimMethod = "MobileMethod"
        end
        
        local w = 1 / #opts
        local mBtns = {}
        for i, opt in ipairs(opts) do
            local b = Instance.new("TextButton", MethodRow)
            b.Size = UDim2.new(w, 0, 1, 0)
            b.Position = UDim2.new(w * (i - 1), 0, 0, 0)
            b.BackgroundColor3 = Shared.SilentAimMethod == opt.id and Color3.fromRGB(150, 30, 30) or Color3.fromRGB(20, 14, 14)
            b.Text = opt.txt
            b.Font = Enum.Font.GothamBold
            b.TextSize = s(11)
            b.TextColor3 = Shared.SilentAimMethod == opt.id and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 120, 120)
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, s(6))
            table.insert(mBtns, {btn=b, id=opt.id})

            b.MouseButton1Click:Connect(function()
                playClick()
                Shared.SilentAimMethod = opt.id
                for _, ob in ipairs(mBtns) do
                    local st = (ob.id == opt.id)
                    ob.btn.BackgroundColor3 = st and Color3.fromRGB(150, 30, 30) or Color3.fromRGB(20, 14, 14)
                    ob.btn.TextColor3 = st and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 120, 120)
                end
                SaveConfig()
                if Shared.SilentAim then Load_SilentMethod() end
            end)
        end
    end
    updateMethods()

    CreateToggle("Enable Silent Aim", "SilentAim", function(st) Load_SilentMethod() end)

    CreateSection("Aiming & Combat")
    CamlockToggleRef = CreateToggle(Shared.Platform == "PC" and "Camlock (Q)" or "Camlock", "Camlock", function(st) Load_CamlockMethod() end)
    CreateToggle("Trigger Bot", "TriggerBot", function(st) if st then Load_TriggerBot() end end)
    CreateToggle("Drag Shoot", "DragShoot", function(st) if st then Load_DragShoot() end end)
    CreateToggle("Instant Stomp", "InstantStomp", function(st) if st then Load_InstantStomp() else Stop_Generic("Schmeckt_InstantStomp_UI", "InstantStompGui") end end)
    CreateToggle("Anti Fling", "AntiFling", function(st) if st then Load_AntiFling() end end)

    CreateSection("Visuals")
    CreateToggle("Target Panel", "TargetPanel", function(st) if st then Load_Target() else Stop_TargetPanel() end end)
    CreateToggle("Visuals & ESP", "VisualPanel", function(st) if st then Load_VisualPanel() else Stop_VisualPanel() end end)

    CreateSection("Automation")
    CreateToggle("Auto Armor", "AutoArmor", function(st) if st then Load_AutoArmor() end end)
    CreateToggle("Auto Reload", "AutoReload", function(st) if st then Load_AutoReload() end end)

    CreateSection("Misc")
    CreateToggle("Player Panel", "PlayerPanel", function(st) if st then Load_PlayerPanel() else Stop_Generic("SchmecktPlayerPanel") end end)
    CreateToggle("Purchase Panel", "PurchasePanel", function(st) if st then Load_PurchasePanel() else Stop_Generic("SchmecktPurchasePanel") end end)
    CreateToggle("Staff Notifier", "StaffNotifier", function(st) if st then Load_StaffNotifier() else Stop_Generic("StaffNotifierGui") Stop_Generic("StaffListGui") end end)

    local lastTick = tick()
    table.insert(RenderConnections, RunService.RenderStepped:Connect(function()
        local cTick = tick()
        FPSLabel.Text = "FPS: " .. math.floor(1 / (cTick - lastTick))
        lastTick = cTick
        pcall(function() PingLabel.Text = "PING: " .. math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) .. "ms" end)
    end))
end

BuildUI()

task.defer(function()
    StartAllScripts()
end)
