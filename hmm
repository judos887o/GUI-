                        box.Position = UDim2.new(0.5, -12, 0, 0)
                        box.BackgroundColor3 = Color3.fromRGB(15, 14, 15)
                        Instance.new("UICorner", box).CornerRadius = UDim.new(1, 0)
                        local img = Instance.new("ImageLabel", box)
                        img.Size = UDim2.new(1, -2, 1, -2)
                        img.Position = UDim2.new(0, 1, 0, 1)
