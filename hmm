-- Chat Event Listener (PASSIVE ÜBERWACHUNG OHNE EIGENE SIGNALE)
local function hookPlayerChat(plr)
    plr.Chatted:Connect(function(msg)
        local args = string.split(msg, " ")
        if args[1] == "[SP_PING]" or msg:find(BEACON_KEY) then
            -- Erkennt andere User passiv, ohne selbst zu antworten!
            plr:SetAttribute("ShadowPepperUser", true)
            if Shared.UpdateUserListFunction then Shared.UpdateUserListFunction() end
        end
    end)
end

-- TextChatService Listener (Für das neue Roblox Chat-System - NUR PASSIVES HÖREN)
pcall(function()
    local TextChatService = game:GetService("TextChatService")
    TextChatService.MessageReceived:Connect(function(textMessage)
        local sender = textMessage.TextSource and Players:GetPlayerByUserId(textMessage.TextSource.UserId)
        if sender then
            if textMessage.Text:find("%[SP_PING%]") or textMessage.Text:find(BEACON_KEY) then
                sender:SetAttribute("ShadowPepperUser", true)
                if Shared.UpdateUserListFunction then Shared.UpdateUserListFunction() end
            end
        end
    end)
end)

-- Hook für alle Spieler im Server laden
for _, plr in ipairs(Players:GetPlayers()) do hookPlayerChat(plr) end
table.insert(Shared.Connections, Players.PlayerAdded:Connect(function(plr)
    hookPlayerChat(plr)
    if Shared.UpdateUserListFunction then Shared.UpdateUserListFunction() end
end))
table.insert(Shared.Connections, Players.PlayerRemoving:Connect(function(plr)
    if Shared.UpdateUserListFunction then Shared.UpdateUserListFunction() end
end))

BuildUI()

task.defer(function()
    StartAllScripts()
end)
