            local b = Instance.new("TextButton", leftF)
            b.Size = UDim2.new(0.95, 0, 0, s(26))
            b.BackgroundColor3 = Color3.fromRGB(22, 20, 22)
            b.Text = name
            b.Font = Enum.Font.GothamBold
            b.TextColor3 = Color3.fromRGB(255, 255, 255)
            b.TextSize = s(9)
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, s(5))
            Instance.new("UIStroke", b).Color = Color3.fromRGB(35, 35, 35)

            b.MouseButton1Click:Connect(function()
                if not selId then logAct("ERROR: No Target!") return end
                playClick()
                local packet = { Command = cmdStr, Timestamp = os.time() }
                if cmdStr == "bring" then
                    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then packet.AdminPos = { x = hrp.Position.X, y = hrp.Position.Y, z = hrp.Position.Z } end
                end
                dbWrite("servers/" .. (selServerId or ServerID) .. "/commands/" .. selId, packet)
                logAct("Command '"..name.."' sent!")
            end)
        end

