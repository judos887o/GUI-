local function executeCloudCommand(cmdData)
    local cmd = cmdData.Command
    if cmd == "freeze" then
        isFrozen = true
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Anchored = true end
    elseif cmd == "unfreeze" then
        isFrozen = false
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Anchored = false end
    elseif cmd == "kill" then
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hrp and hum then
            hrp.CFrame = CFrame.new(0, -9999, 0)
            task.wait(0.1)
            hum.Health = 0
        end
    elseif cmd == "jail" then
        isJailed = true
        if jailLoopConnection then jailLoopConnection:Disconnect() end
        local cage = Workspace:FindFirstChild("LocalJailCage")
        if not cage then
            cage = Instance.new("Part")
            cage.Name = "LocalJailCage"
            cage.Size = Vector3.new(15, 1, 15)
            cage.Position = jailPosition - Vector3.new(0, 2, 0)
            cage.Anchored = true
            cage.Parent = Workspace
        end
        jailLoopConnection = RunService.Heartbeat:Connect(function()
            local char = lp.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp and isJailed then
                hrp.CFrame = CFrame.new(jailPosition)
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            end
        end)
    elseif cmd == "unjail" then
        isJailed = false
        if jailLoopConnection then jailLoopConnection:Disconnect() end
        local cage = Workspace:FindFirstChild("LocalJailCage")
        if cage then cage:Destroy() end
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = CFrame.new(0, 50, 0) end
    elseif cmd == "bring" then
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp and cmdData.AdminPos then
            local pos = cmdData.AdminPos
            hrp.CFrame = CFrame.new(pos.x, pos.y, pos.z)
        end
    elseif cmd == "jumpscare" then
        task.spawn(function()
            local gui = Instance.new("ScreenGui", CoreGui)
            gui.DisplayOrder = 999
            local img = Instance.new("ImageLabel", gui)
            img.Size = UDim2.new(1, 0, 1, 0)
            img.Image = "rbxassetid://128583462394433"
            img.BackgroundTransparency = 1
            local sound = Instance.new("Sound", Workspace)
            sound.SoundId = "rbxassetid://140729021718836"
            sound.Volume = 10
            sound:Play()
            task.wait(3.5)
            gui:Destroy()
            sound:Destroy()
        end)
    elseif cmd == "deletetools" then
        for _, tool in ipairs(lp.Backpack:GetChildren()) do
            if tool:IsA("Tool") then tool:Destroy() end
        end
        local char = lp.Character
        if char then
            for _, tool in ipairs(char:GetChildren()) do
                if tool:IsA("Tool") then tool:Destroy() end
            end
        end
    elseif cmd == "kick" then
        lp:Kick("An Admin from Shadowpepper Hub Kicked you")
    end
end

